  speaker: {fileID: 0}
  messageText: "\u041D\u043E\u0432\u0435\u0439\u0448\u0430\u044F, \u0441\u0432\u0435\u0436\u0430\u0439\u0448\u0430\u044F,
    \u043A\u0440\u0443\u0442\u0435\u0439\u0448\u0430\u044F \u043D\u0430\u0441\u0442\u043E\u043B\u043A\u0430
    \u043F\u043E \xAB\u041F\u043E\u0434\u0437\u0435\u043C\u0435\u043B\u044C\u044F\u043C
    \u0438 \u0434\u0440\u0430\u043A\u043E\u043D\u0430\u043C\xBB! \u041D\u0435 \u0442\u0435\u0440\u043F\u0438\u0442\u0441\u044F
    \u0443\u0436\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C,
    \u043D\u043E \u0432\u0441\u0435 \u043C\u043E\u0438 \u043C\u044B\u0441\u043B\u0438
    \u0437\u0430\u043D\u044F\u0442\u044B \u0442\u0435\u043C \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u043C
    \u043F\u0438\u0441\u044C\u043C\u043E\u043C \u0438 \u0441\u043F\u043E\u0440\u043E\u043C
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439. \u041F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
    \u0442\u0435\u0431\u0435 \u043F\u043E\u0442\u0435\u0440\u043F\u0435\u0442\u044C,
    \u043F\u043E\u0434\u0437\u0435\u043C\u0435\u043B\u044C\u0435 \u0417\u0430\u043D\u0437\u0435\u0440\u0430!"
